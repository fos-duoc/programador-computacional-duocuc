---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const bimestres = await getCollection("bimestres");
  return bimestres.map((b) => ({
    params: { slug: b.data.slug },
    props: { entry: b },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, bimestre, status, asignaturas } = entry.data;

const statusLabel = {
  pending: "Pendiente",
  current: "En curso",
  done: "Completado",
}[status];

const statusColor = {
  pending: "#94a3b8",
  current: "#f59e0b",
  done: "#10b981",
}[status];
---

<Layout title={`${title} — Bimestre ${bimestre}`}>
  <main class="bimestre-detail">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={`${import.meta.env.BASE_URL}/inicio`}>Inicio</a>
      <span aria-hidden="true">/</span>
      <a href={`${import.meta.env.BASE_URL}/bimestres`}>Bimestres</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Bimestre {bimestre}</span>
    </nav>

    <header class="bimestre-header">
      <div class="bimestre-meta">
        <span class="bimestre-number">Bimestre {String(bimestre).padStart(2, "0")}</span>
        <span class="bimestre-status" style={`background:${statusColor}`}>
          {statusLabel}
        </span>
      </div>
      <h1>{title}</h1>
      <p class="asignaturas-count">
        {asignaturas.length} asignatura{asignaturas.length === 1 ? "" : "s"}
      </p>
    </header>

    <article class="bimestre-content prose">
      <Content />
    </article>
  </main>
</Layout>

<style>
  .bimestre-detail {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted, #64748b);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .bimestre-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border, #e2e8f0);
  }

  .bimestre-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .bimestre-number {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.875rem;
    color: var(--color-text-muted, #64748b);
    letter-spacing: 0.05em;
  }

  .bimestre-status {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .bimestre-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.2;
    margin: 0.5rem 0;
  }

  .asignaturas-count {
    color: var(--color-text-muted, #64748b);
    font-size: 0.9375rem;
  }

  .bimestre-content :global(h1) {
    display: none; /* Ya mostramos el título en el header */
  }

  .bimestre-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .bimestre-content :global(pre) {
    background: var(--color-code-bg, #1e293b);
    color: var(--color-code-fg, #e2e8f0);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    font-size: 0.875rem;
  }

  .bimestre-content :global(code):not(:global(pre code)) {
    background: var(--color-code-inline-bg, #f1f5f9);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875em;
  }
</style>
