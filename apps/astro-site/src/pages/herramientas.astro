---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const tools = (await getCollection("tools")).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.name.localeCompare(b.data.name);
});

const categories = [
  { id: "all", label: "Todas", count: tools.length },
  {
    id: "generadores",
    label: "Generadores",
    count: tools.filter((t) => t.data.category === "generadores").length,
  },
  {
    id: "gestion",
    label: "Gestión",
    count: tools.filter((t) => t.data.category === "gestion").length,
  },
  {
    id: "utilidades",
    label: "Utilidades",
    count: tools.filter((t) => t.data.category === "utilidades").length,
  },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Herramientas — Índice unificado">
  <main class="tools-index">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={`${base}/inicio`}>Inicio</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Herramientas</span>
    </nav>

    <header class="page-header">
      <h1>Herramientas interactivas</h1>
      <p class="lead">
        {tools.length} generadores y utilidades del sitio. Filtra por categoría o busca por nombre de
        asignatura.
      </p>
    </header>

    <div class="filters" role="tablist" aria-label="Filtrar por categoría">
      {
        categories.map((c, i) => (
          <button class:list={["filter-chip", { active: i === 0 }]} data-category={c.id} role="tab">
            {c.label} <span class="count">{c.count}</span>
          </button>
        ))
      }
    </div>

    <ul class="tools-grid">
      {
        tools.map((t) => (
          <li class="tool-card" data-category={t.data.category}>
            <a href={`${base}${t.data.url}`}>
              <div class="tool-icon">
                {t.data.iconType === "devicon" ? (
                  <i class={`devicon ${t.data.icon}`} aria-hidden="true" />
                ) : (
                  <i class={t.data.icon} aria-hidden="true" />
                )}
              </div>
              <div class="tool-body">
                <div class="tool-meta">
                  <span class={`category category-${t.data.category}`}>{t.data.category}</span>
                  {t.data.featured && <span class="featured">⭐ Destacado</span>}
                </div>
                <h2>{t.data.name}</h2>
                <p>{t.data.descripcion}</p>
                {t.data.bimestres.length > 0 && (
                  <div class="bimestres-tags">
                    {t.data.bimestres.slice(0, 4).map((b) => (
                      <span class="bimestre-tag">B{String(b).padStart(2, "0")}</span>
                    ))}
                    {t.data.bimestres.length > 4 && (
                      <span class="bimestre-tag more">+{t.data.bimestres.length - 4}</span>
                    )}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>

<script is:inline>
  (function () {
    const chips = document.querySelectorAll(".filter-chip");
    const cards = document.querySelectorAll(".tool-card");

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const category = chip.getAttribute("data-category");
        chips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        cards.forEach((card) => {
          const match = category === "all" || card.getAttribute("data-category") === category;
          card.style.display = match ? "" : "none";
        });
      });
    });
  })();
</script>

<style>
  .tools-index {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted, #64748b);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 0.5rem;
  }

  .lead {
    font-size: 1.0625rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 70ch;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-chip {
    background: var(--bg-card, #15151f);
    border: 1px solid var(--border-color, rgba(255, 255, 255, 0.08));
    color: var(--text-secondary, #94a3b8);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .filter-chip:hover {
    border-color: var(--accent-primary, #00d4ff);
    color: var(--text-primary, #f8fafc);
  }

  .filter-chip.active {
    background: var(--accent-primary, #00d4ff);
    color: var(--bg-primary, #0a0a0f);
    border-color: var(--accent-primary, #00d4ff);
  }

  .count {
    opacity: 0.6;
    margin-left: 0.25rem;
  }

  .tools-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    background: var(--bg-card, #15151f);
    border: 1px solid var(--border-color, rgba(255, 255, 255, 0.08));
    border-radius: 12px;
    overflow: hidden;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      border-color 0.15s ease;
  }

  .tool-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-primary, #00d4ff);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .tool-card a {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .tool-icon {
    flex: 0 0 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-tertiary, #1a1a24);
    border-radius: 10px;
    font-size: 1.5rem;
    color: var(--accent-primary, #00d4ff);
  }

  .tool-body {
    flex: 1;
    min-width: 0;
  }

  .tool-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .category {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .category-generadores {
    background: rgba(0, 212, 255, 0.15);
    color: #00d4ff;
  }

  .category-gestion {
    background: rgba(124, 58, 237, 0.15);
    color: #a78bfa;
  }

  .category-utilidades {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }

  .featured {
    font-size: 0.6875rem;
    color: var(--warning, #f59e0b);
  }

  .tool-card h2 {
    font-size: 1rem;
    margin: 0 0 0.375rem;
    line-height: 1.3;
  }

  .tool-card p {
    font-size: 0.875rem;
    color: var(--text-secondary, #94a3b8);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .bimestres-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .bimestre-tag {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.6875rem;
    padding: 0.125rem 0.375rem;
    background: var(--bg-tertiary, #1a1a24);
    border-radius: 4px;
    color: var(--text-muted, #64748b);
  }

  .bimestre-tag.more {
    color: var(--text-secondary, #94a3b8);
  }
</style>
